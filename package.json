{
  "name": "taskpulse",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@8.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @taskpulse/api prisma:generate",
    "db:migrate": "pnpm --filter @taskpulse/api prisma:migrate",
    "seed": "pnpm --filter @taskpulse/api seed"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "turbo": "^1.13.4",
    "typescript": "^5.9.3"
  }
}
